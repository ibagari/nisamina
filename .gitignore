# Large textbook library content (source-of-truth lives elsewhere)
50_app/lms/*/curriculum_source/*/
!50_app/lms/*/curriculum_source/*/.gitkeep
!50_app/lms/*/curriculum_source/README.md
!50_app/lms/*/curriculum_source/STATUS.md

# Foundry corpus binary file (canonical source-of-truth at 30_lexicon/; deploy via HfApi)
30_lexicon/foundry_v6/*.jsonl
30_lexicon/foundry_v6/*.parquet

# Quarantine paths
*_quarantine_*/

# OS / editor
Thumbs.db

# macOS dotbar files
._*
